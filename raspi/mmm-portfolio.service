[Unit]
Description=MMM-Portfolio API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rene
WorkingDirectory=/home/rene/mmm-portfolio-api
ExecStart=/home/rene/mmm-portfolio-api/venv/bin/python /home/rene/mmm-portfolio-api/portfolio_api.py
Restart=always
RestartSec=10
Environment=PATH=/home/rene/mmm-portfolio-api/venv/bin:/usr/bin

[Install]
WantedBy=multi-user.target
